{
  "name": "snaptrack",
  "version": "1.0.0",
  "description": "SnapTrack — Track Every Moment",
  "main": "electron.cjs",
  "scripts": {
    "dev:vite": "vite",
    "dev:electron": "electron .",
    "dev": "concurrently -k \"npm:dev:vite\" \"npm:dev:electron\"",
    "build": "vite build",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "vite": "^8.0.3",
    "vite-plugin-singlefile": "^2.3.2"
  },
  "build": {
    "appId": "com.snaptrack.timetracker",
    "productName": "SnapTrack",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true
    },
    "files": [
      "dist/**/*",
      "electron.cjs",
      "preload.cjs"
    ]
  }
}
